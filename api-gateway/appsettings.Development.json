{
  "JwtSettings": {
    "Issuer": "AUTH-service",
    "Audience": "platform-services",
    "Key": "qsjhdhqsdhhuzhdhdgeudgudsgv,nfkuhzgezfuvjhknfjhsdbgvsqjhvvudsdfhvfuzbhjdqsjbddahugfu"
  },

  "AllowedOrigins": [
    "https://business-pulse-two.vercel.app",
    "*"
  ],

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}",
          "Methods": [ "GET", "POST", "OPTIONS" ]
        },
        "Transforms": [
          { "RequestHeader": "X-Forwarded-Prefix", "Set": "/api/auth" },
          { "RequestHeader": "X-Gateway-Version", "Set": "1.0" },
          { "ResponseHeader": "X-Frame-Options", "Set": "DENY" },
          { "ResponseHeader": "X-Content-Type-Options", "Set": "nosniff" }
        ]
      },
      "chat-route": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/api/chat/{**catch-all}",
          "Methods": [ "GET", "POST", "DELETE", "OPTIONS" ]
        },
        "Transforms": [
          { "RequestHeader": "X-Forwarded-Prefix", "Set": "/api/chat" },
          { "ResponseHeader": "X-Frame-Options", "Set": "DENY" },
          { "ResponseHeader": "X-Content-Type-Options", "Set": "nosniff" }
        ]
      },
      "mdx-route": {
        "ClusterId": "mdx-cluster",
        "Match": {
          "Path": "/api/mdx/{**catch-all}",
          "Methods": [ "GET", "POST", "OPTIONS" ]
        },
        "Transforms": [
          { "RequestHeader": "X-Forwarded-Prefix", "Set": "/api/mdx" },
          { "ResponseHeader": "X-Frame-Options", "Set": "DENY" },
          { "ResponseHeader": "X-Content-Type-Options", "Set": "nosniff" }
        ]
      },
      "etl-route": {
        "ClusterId": "etl-cluster",
        "Match": {
          "Path": "/api/etl/{**catch-all}",
          "Methods": [ "POST", "PUT", "OPTIONS" ]
        },
        "Transforms": [
          { "RequestHeader": "X-Forwarded-Prefix", "Set": "/api/etl" },
          { "ResponseHeader": "X-Frame-Options", "Set": "DENY" },
          { "ResponseHeader": "X-Content-Type-Options", "Set": "nosniff" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth1": {
            "Address": "http://auth-service:8080/"
          }
        }
      },
      "chat-cluster": {
        "Destinations": {
          "chat1": {
            "Address": "http://chatbot-service:8080/"
          }
        }
      },
      "mdx-cluster": {
        "Destinations": {
          "mdx1": {
            "Address": "http://mdx-service:8080/"
          }
        }
      },
      "etl-cluster": {
        "Destinations": {
          "etl1": {
            "Address": "http://etl-service:8080/"
          }
        }
      }
    }
  }
}