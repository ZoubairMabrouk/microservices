  },
  "Jwt": {
    "SecretKey": "qsjhdhqsdhhuzhdhdgeudgudsgv,nfkuhzgezfuvjhknfjhsdbgvsqjhvvudsdfhvfuzbhjdqsjbddahugfu",
    "Issuer": "AUTH-Sevice",
    "Audience": "platform-services",
    "AccessTokenExpiryMinutes": 15,
